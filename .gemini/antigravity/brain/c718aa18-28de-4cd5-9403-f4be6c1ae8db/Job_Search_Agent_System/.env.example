# Job Search Agent — variables d'environnement
# Copier en .env et renseigner les valeurs
#
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
# PROFILE_JSON_PATH=resources/cv_base_datas_pour_candidatures.json
#
# SquidResearch (optionnel) — pour offer/submit externe
# SQUID_API_URL=https://api.squidresearch.fr
# SQUID_API_TOKEN=...

# Telegram Bot — controle a distance (priorite)
# TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_ALLOWED_IDS=123456789
